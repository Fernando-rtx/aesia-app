rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidRecord() {
      let data = request.resource.data;
      return data.uid == request.auth.uid
        && data.carnet is string
        && data.carnet.size() > 0 && data.carnet.size() <= 20
        && data.action in ['entrada', 'salida']
        && data.outOfBounds is bool
        && data.timestamp is string
        && data.userEmail is string;
    }

    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    match /members/{carnet} {
      // get público para validar carnet en registro, list protegido
      allow get: if true;
      allow list: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /records/{recordId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.uid == request.auth.uid);
      allow create: if request.auth != null && isValidRecord();
      allow delete: if isAdmin();
    }
  }
}