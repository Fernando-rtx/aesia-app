rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper: ¿el usuario actual es admin? ────────────────────────────────
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ─── Helper: validar que un record tenga datos correctos ─────────────────
    function isValidRecord() {
      let data = request.resource.data;
      return data.uid == request.auth.uid
        && data.carnet is string
        && data.carnet.size() > 0 && data.carnet.size() <= 20
        && data.action in ['entrada', 'salida']
        && data.outOfBounds is bool
        && data.timestamp is string
        && data.userEmail is string;
    }

    // ADMINS: solo el propio admin lee su doc. Nadie escribe vía cliente.
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // MIEMBROS:
    // - Cualquier autenticado puede leer
    // - Un usuario puede CREAR su propio perfil (auto-registro) si el uid coincide
    // - Solo admins pueden actualizar o eliminar
    match /members/{carnet} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // REGISTROS:
    // - Admins leen todos; usuarios leen solo los suyos
    // - Cualquier autenticado puede crear si los datos son válidos
    // - Solo admins pueden eliminar
    match /records/{recordId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.uid == request.auth.uid);
      allow create: if request.auth != null && isValidRecord();
      allow delete: if isAdmin();
    }
  }
}
