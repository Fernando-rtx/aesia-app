rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper: ¿el usuario actual es admin? ────────────────────────────────
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ─── Helper: ¿el documento de record tiene datos válidos? ────────────────
    // Verifica que los campos sean del tipo correcto y que el uid del registro
    // corresponda al usuario que está haciendo el request. Esto impide que
    // alguien inyecte registros falsos a nombre de otro usuario.
    function isValidRecord() {
      let data = request.resource.data;
      return data.uid == request.auth.uid              // El uid debe ser del creador
        && data.carnet is string                       // carnet es texto
        && data.carnet.size() > 0
        && data.carnet.size() <= 20
        && data.action in ['entrada', 'salida']        // Solo valores permitidos
        && data.outOfBounds is bool                    // Debe ser booleano
        && data.timestamp is string                    // ISO string
        && data.userEmail is string;                   // Email es texto
    }

    // ADMINS: solo el propio admin lee su doc. Nadie escribe vía cliente.
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // Solo via consola Firebase o Admin SDK
    }

    // MIEMBROS: cualquier usuario autenticado lee, solo admins escriben/eliminan
    match /members/{carnet} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }

    // REGISTROS:
    // - Admins leen TODO el historial
    // - Usuarios normales solo leen sus PROPIOS registros
    // - Cualquier autenticado puede crear registros SI los datos son válidos
    // - Solo admins pueden eliminar
    match /records/{recordId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.uid == request.auth.uid);
      allow create: if request.auth != null && isValidRecord();
      allow delete: if isAdmin();
    }
  }
}
